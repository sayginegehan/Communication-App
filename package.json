{
  "name": "golge-ses-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:socket\"",
    "dev:web": "next dev",
    "dev:socket": "node server.js",
    "build": "next build",
    "start": "concurrently \"npm run start:web\" \"npm run start:socket:stacked\"",
    "start:web": "next start",
    "start:socket": "node server.js",
    "start:socket:stacked": "node scripts/start-socket-stacked.cjs",
    "start:socket:only": "node server.js",
    "lint": "eslint",
    "test": "vitest run",
    "prisma:generate": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.7.0",
    "bcryptjs": "^3.0.2",
    "cookie-parser": "^1.4.7",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "prisma": "^6.7.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
