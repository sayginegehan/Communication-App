generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Room {
  id          String      @id @default(cuid())
  roomId      String      @unique
  type        String      @default("room")
  serverId    String?
  name        String?
  description String?
  topic       String?
  deletedAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  messages    Message[]
  events      RoomEvent[]

  @@index([type, deletedAt])
  @@index([serverId, deletedAt])
}

model Message {
  id         String   @id @default(cuid())
  externalId String
  roomId     String
  sender     String
  text       String
  sentAt     DateTime @default(now())
  room       Room     @relation(fields: [roomId], references: [roomId], onDelete: Cascade)

  @@index([roomId, sentAt])
}

model RoomEvent {
  id        String   @id @default(cuid())
  roomId    String
  type      String
  socketId  String
  userName  String?
  createdAt DateTime @default(now())
  room      Room     @relation(fields: [roomId], references: [roomId], onDelete: Cascade)

  @@index([roomId, createdAt])
}
