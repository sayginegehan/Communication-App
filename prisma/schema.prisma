generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Room {
  id          String      @id @default(cuid())
  roomId      String      @unique
  type        String      @default("room")
  serverId    String?
  name        String?
  description String?
  topic       String?
  deletedAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  messages    Message[]
  events      RoomEvent[]

  @@index([type, deletedAt])
  @@index([serverId, deletedAt])
}

model Message {
  id         String   @id @default(cuid())
  externalId String
  roomId     String
  sender     String
  text       String
  sentAt     DateTime @default(now())
  room       Room     @relation(fields: [roomId], references: [roomId], onDelete: Cascade)

  @@index([roomId, sentAt])
}

model RoomEvent {
  id        String   @id @default(cuid())
  roomId    String
  type      String
  socketId  String
  userName  String?
  createdAt DateTime @default(now())
  room      Room     @relation(fields: [roomId], references: [roomId], onDelete: Cascade)

  @@index([roomId, createdAt])
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  username     String         @unique
  passwordHash String
  createdAt    DateTime       @default(now())
  memberships  ServerMember[]
  messages     ChannelMessage[]
}

model ServerEntity {
  id        String         @id @default(cuid())
  name      String
  ownerId   String
  createdAt DateTime       @default(now())
  channels  Channel[]
  members   ServerMember[]
}

model ServerMember {
  id        String       @id @default(cuid())
  userId    String
  serverId  String
  role      String       @default("member")
  joinedAt  DateTime     @default(now())
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  server    ServerEntity @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([userId, serverId])
}

model Channel {
  id        String           @id @default(cuid())
  serverId  String
  name      String
  type      String           @default("text")
  createdAt DateTime         @default(now())
  server    ServerEntity     @relation(fields: [serverId], references: [id], onDelete: Cascade)
  messages  ChannelMessage[]
}

model ChannelMessage {
  id        String   @id @default(cuid())
  channelId String
  userId    String
  content   String
  createdAt DateTime @default(now())
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
